# TuneCamp Peer Daemon Configuration

# The URL of the TuneCamp server
TUNECAMP_SERVER=http://localhost:1970

# Your JWT authentication token or developer token
TUNECAMP_TOKEN=your_jwt_token_here

# Local directories to share (comma-separated list)
TUNECAMP_SHARE=C:/Music/Albums,D:/Downloads/Music

# Set to false to only allow streaming (no downloading)
TUNECAMP_ALLOW_DOWNLOADS=true
